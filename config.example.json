{
  "_comment": "Unified configuration supporting multiple remotes (inbound and outbound)",
  
  "server": {
    "listen": "127.0.0.1:8787",
    "unix": "/run/user/1000/notify-relay.sock"
  },
  
  "remotes": [
    {
      "_comment": "Inbound remote: watch for forwarded socket from laptop",
      "name": "laptop-work",
      "type": "inbound",
      "socket": "/run/user/1000/notify-relay-laptop-work.sock",
      "priority": 1
    },
    {
      "_comment": "Inbound remote: pattern matching for multiple laptops",
      "name": "laptop-personal",
      "type": "inbound", 
      "socket": "/run/user/1000/notify-relay-laptop-personal.sock",
      "priority": 2
    },
    {
      "_comment": "Outbound remote: connect to another server",
      "name": "backup-server",
      "type": "outbound",
      "host": "backup.example.com:8787",
      "token": "auth-token",
      "priority": 3
    }
  ],
  
  "channels": {
    "dbus": {
      "type": "dbus"
    },
    "phone": {
      "type": "ntfy",
      "config": {
        "server": "https://ntfy.sh",
        "topic": "my-notifications"
      }
    }
  },
  
  "routes": [
    {
      "condition": "remote_unlocked",
      "channel": "forward"
    },
    {
      "condition": "screen_locked",
      "channel": "phone"
    },
    {
      "condition": "always",
      "channel": "dbus"
    }
  ]
}
